<div class="author">
  <h1 class="author__heading">Hello and Welcome to My Pup Task Manager App</h1>
  <p class="author__body">Here you can manage your own tasks for your fluffy companions!</p>
</div>

<img src="img/apple.jpeg" alt="apple" />

<section class="articles">
  <h2 class="articles__heading">Latest Posts</h2>

  <!--Posts-->
  <ul class="articles-ul">
    <% data.forEach(post => { %>
      <li>
        <a href="/post/<%= post.id %>">
          <span><%= post.title %></span>
          <span class="article-list__date"><%= post.date %>
          <% post.createdAt.toDateString() %>
          </span>
        </a>
      </li>
    <%});%>
  </ul>

    <% if (nextPage !== null) { %>
  <a href="/?page=<%= nextPage %>" class="pagination">&lt; View Older tasks</a>
  <% } %>

  <!-- if prevPage is 1 then go to / -->
  <% if (prevPage >= 1) { %> <% if (prevPage === 1) { %>
  <a href="/" class="pagination-newpage">View Newer tasks &gt;</a>
  <% } else { %>
  <a href="/?page=<%= prevPage %>" class="pagination-newpage"
    >View Newer Tasks &gt;</a
  >
  <% } %> <% } %>


</section>